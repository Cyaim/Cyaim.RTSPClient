<Window x:Class="Cyaim.RTSPServer.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyaim RTSP Server Dashboard" 
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#1a73e8" Padding="16,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📡" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Cyaim RTSP Server" 
                               FontSize="20" FontWeight="Bold" 
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="● Running" 
                               Foreground="#4caf50" FontSize="14" 
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="⚙ Settings" Style="{StaticResource PrimaryButton}" 
                            Click="OnSettingsClick" Margin="0,0,8,0"/>
                    <Button x:Name="StartStopButton" Content="⏹ Stop" 
                            Style="{StaticResource DangerButton}" 
                            Click="OnStartStopClick"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="16">
            
            <!-- Dashboard Tab -->
            <TabItem Header="📊 Dashboard">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Stats Cards -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Style="{StaticResource CardStyle}" Width="200">
                            <StackPanel>
                                <TextBlock Text="Active Streams" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="ActiveStreamsCount" Text="0" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}" Width="200">
                            <StackPanel>
                                <TextBlock Text="Connected Clients" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="ConnectedClientsCount" Text="0" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}" Width="200">
                            <StackPanel>
                                <TextBlock Text="Total Bandwidth" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="BandwidthText" Text="0 Mbps" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>
                        
                        <Border Style="{StaticResource CardStyle}" Width="200">
                            <StackPanel>
                                <TextBlock Text="Uptime" Style="{StaticResource StatLabel}"/>
                                <TextBlock x:Name="UptimeText" Text="00:00:00" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    
                    <!-- Streams List -->
                    <DataGrid Grid.Row="1" x:Name="StreamsGrid" 
                              AutoGenerateColumns="False" 
                              IsReadOnly="True"
                              Margin="0,16,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="200"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Codec" Binding="{Binding VideoCodec}" Width="100"/>
                            <DataGridTextColumn Header="Resolution" Binding="{Binding Resolution}" Width="120"/>
                            <DataGridTextColumn Header="Clients" Binding="{Binding ActiveClients}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                            <DataGridTemplateColumn Header="Actions" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="▶" Margin="4,0" Padding="8,4"/>
                                            <Button Content="⏹" Margin="4,0" Padding="8,4"/>
                                            <Button Content="🗑" Margin="4,0" Padding="8,4"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
            <!-- Streams Tab -->
            <TabItem Header="📺 Streams">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Stream List -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Streams" FontSize="16" FontWeight="Bold" 
                                          VerticalAlignment="Center"/>
                                <Button Content="+" Style="{StaticResource PrimaryButton}" 
                                        Click="OnAddStream" Margin="8,0,0,0" Padding="12,4"/>
                            </StackPanel>
                            
                            <ListBox x:Name="StreamList" SelectionChanged="OnStreamSelected"/>
                        </DockPanel>
                    </Border>
                    
                    <!-- Stream Details -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,8,0,8">
                        <ScrollViewer>
                            <StackPanel x:Name="StreamDetailsPanel">
                                <TextBlock Text="Select a stream to view details" 
                                          Foreground="#999" FontStyle="Italic"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
            
            <!-- Logs Tab -->
            <TabItem Header="📋 Logs">
                <Border Style="{StaticResource CardStyle}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Clear" Style="{StaticResource PrimaryButton}" 
                                    Click="OnClearLogs" Padding="12,4"/>
                            <CheckBox Content="Auto-scroll" IsChecked="True" 
                                     VerticalAlignment="Center" Margin="16,0"/>
                        </StackPanel>
                        
                        <TextBox x:Name="LogsTextBox" 
                                 IsReadOnly="True" 
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Background="#1e1e1e"
                                 Foreground="#d4d4d4"/>
                    </DockPanel>
                </Border>
            </TabItem>
            
            <!-- Settings Tab -->
            <TabItem Header="⚙ Settings">
                <Border Style="{StaticResource CardStyle}">
                    <ScrollViewer>
                        <StackPanel MaxWidth="600">
                            <TextBlock Text="Server Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="HostTextBox" Text="0.0.0.0" Margin="0,4"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Port:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="PortTextBox" Text="554" Margin="0,4"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Max Connections:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="MaxConnectionsTextBox" Text="10000" Margin="0,4"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Session Timeout:" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TimeoutTextBox" Text="60" Margin="0,4"/>
                                
                                <CheckBox Grid.Row="4" Grid.Column="1" x:Name="EnableAuthCheckBox" 
                                          Content="Enable Authentication" Margin="0,8"/>
                            </Grid>
                            
                            <Button Content="Save Settings" Style="{StaticResource PrimaryButton}" 
                                    Click="OnSaveSettings" Margin="0,24,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
